# Copy this to .env and fill in values.
# .env is gitignored — never commit real credentials.

# ── Agent URLs ────────────────────────────────────────────────────────────────
# Development defaults (all on localhost with mock servers)
PARTICIPANT_URL=http://localhost:8001
COMPANION_URL=http://localhost:8002
CURRICULUM_URL=http://localhost:8003
ASSESSMENT_URL=http://localhost:8004

# Production example (Azure Container Apps)
# PARTICIPANT_URL=https://participant-agent.azurecontainerapps.io
# COMPANION_URL=https://lab-companion.azurecontainerapps.io
# CURRICULUM_URL=https://curriculum-designer.azurecontainerapps.io
# ASSESSMENT_URL=https://assessment-agent.azurecontainerapps.io

# ── Session store ─────────────────────────────────────────────────────────────
# In-memory TTL (seconds). Sessions older than this are evicted.
SESSION_TTL_SECONDS=3600
